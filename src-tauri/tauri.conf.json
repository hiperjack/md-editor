{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdedit",
  "version": "1.7.0",
  "identifier": "com.mdedit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mdedit",
        "width": 1100,
        "height": 720,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown File",
        "description": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": ["mmd", "mermaid"],
        "name": "Mermaid Diagram",
        "description": "Mermaid Diagram File",
        "role": "Editor"
      }
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "wix": {
        "language": "ja-JP"
      }
    }
  }
}
